LLM_PROVIDER=mock
LOG_LEVEL=qwen3.6-27b


# =============================================================================
# 1. LLM PROVIDER (REQUIRED)
# =============================================================================

# Option A: Mock (free, no key, for testing)
#LLM_PROVIDER=mock
#LLM_MODEL=qwen3.6-27b

# Option B: OpenAI (production)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4

# Option C: Ollama (local, free)
# LLM_PROVIDER=ollama
# LLM_API_URL=http://localhost:11434
# LLM_MODEL=llama3

# LLM behavior
#LLM_TIMEOUT=30
#LLM_MAX_RETRIES=3
#LLM_TEMPERATURE=0.1

# =============================================================================
# 2. DATABASE
# =============================================================================

# DuckDB (local file, default)
#DUCKDB_PATH=data/analyst.db

# PostgreSQL (production)
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=analytics
# PG_USER=analyst
# PG_PASSWORD=your-password

# MySQL
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=analytics
# MYSQL_USER=analyst
# MYSQL_PASSWORD=your-password

# Query limits
#MAX_QUERY_ROWS=10000
#QUERY_TIMEOUT=60

# =============================================================================
# 3. RAG / SEMANTIC SEARCH
# =============================================================================

#RAG_PROVIDER=simple
# RAG_PROVIDER=pgvector
# PGVECTOR_HOST=localhost
# PGVECTOR_DATABASE=analytics
# PGVECTOR_USER=analyst
# PGVECTOR_PASSWORD=your-password

# =============================================================================
# 4. SANDBOX
# =============================================================================

#SANDBOX_USE_DOCKER=false
#SANDBOX_TIMEOUT=30

# =============================================================================
# 5. RATE LIMITING
# =============================================================================

#RATE_LIMIT_REQUESTS=60
#RATE_LIMIT_WINDOW=60

# =============================================================================
# 6. LOGGING
# =============================================================================

#LOG_LEVEL=INFO
#LOG_FORMAT=json

# =============================================================================
# 7. COST / BUDGET GUARDRAILS
# =============================================================================

#USER_DAILY_BUDGET=50.0
#GLOBAL_DAILY_BUDGET=1000.0

# =============================================================================
# 8. SECURITY
# =============================================================================

# JWT_SECRET=your-256-bit-secret
# ADMIN_USER_ID=admin
# ADMIN_EMAIL=admin@company.com